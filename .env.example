# Copie para .env.local e preencha (nunca commite .env.local).
# Supabase: Project Settings → API → Project URL e anon (public) key.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# WhatsApp (opcional): só dígitos, código do país + DDD + número. Na Vercel: Environment Variables.
# VITE_WHATSAPP_PHONE=5521966225632

# Extração de lead com IA (somente servidor — NÃO use prefixo VITE_)
# Vercel: Project → Settings → Environment Variables → Add Secret
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
