# Copie para .env.local e preencha (nunca commite .env.local).
# Supabase: Project Settings → API → Project URL e anon (public) key.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Apagar leads no admin (somente servidor — service role, nunca VITE_)
# Supabase: Project Settings → API → service_role secret
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp (opcional): só dígitos, código do país + DDD + número. Na Vercel: Environment Variables.
# VITE_WHATSAPP_PHONE=5521966225632

# Extração de lead com IA (somente servidor — NÃO use prefixo VITE_)
# Vercel: Project → Settings → Environment Variables → Add Secret
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# HubSpot CRM (somente servidor — Private App token, escopo crm.objects.contacts.read)
# HUBSPOT_ACCESS_TOKEN=pat-na1-...
HUBSPOT_ACCESS_TOKEN=

# Gmail OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0)
# Ative Gmail API. Redirect URI autorizado (dev): http://localhost:8080/api/gmail-oauth-callback
# Produção: https://buildai.dev.br/api/gmail-oauth-callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/gmail-oauth-callback
